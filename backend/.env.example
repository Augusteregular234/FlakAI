# Copiar a `.env` en esta carpeta (`backend/`).

# Seguridad (obligatorio en producción)
JWT_SECRET=cambia-esto-en-produccion

# Base de datos — MVP SQLite local
DATABASE_URL=sqlite:///./flak_ai.db
# Producción ejemplo:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/flakai

# FFmpeg (opcional): rutas absolutas en Windows si no están en PATH
# FFMPEG_PATH=C:\ruta\ffmpeg.exe
# FFPROBE_PATH=C:\ruta\ffprobe.exe

# Carpeta con vídeos de partidos para dataset / entrenamiento (solo lectura)
DATASET_VIDEOS_DIR=C:\Users\saamu\Videos\analisisia

# Motor de detección: mock hasta integrar modelo real
DETECTOR_BACKEND=mock
MODEL_VERSION=mock-1.0.0

# Ventana de clip (segundos antes del evento) y umbral de auto-aprobación
CLIP_WINDOW_SECONDS=30
AUTO_APPROVE_CONFIDENCE=80

# --- Stripe (pagos) ---
# Obtén las claves en https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs de precio de los productos en Stripe (modo test)
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_CLUB=price_...
# URL pública de la app (para redirects de Stripe)
APP_URL=http://localhost:3000
